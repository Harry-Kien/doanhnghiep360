<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_Legal360" targetNamespace="https://legal360.local/bpmn">
  <bpmn:process id="Process_Legal360" name="Legal360 - Enterprise Legal Survey Workflow" isExecutable="false">
    <bpmn:laneSet id="LaneSet_Legal360">
      <bpmn:lane id="lane_customer" name="Khach hang">
        <bpmn:flowNodeRef>start</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>landing</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>intake_form</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>otp</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>payment</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>upload_docs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_system" name="He thong / Database">
        <bpmn:flowNodeRef>create_lead</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>open_case</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>store_docs</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_intake" name="Intake / Sales / Legal Ops">
        <bpmn:flowNodeRef>receive_lead</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>check_info</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_conflict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>stop_conflict</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>proposal</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_docs" name="Staff / Ho so">
        <bpmn:flowNodeRef>check_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_docs</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>request_more</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>handoff_ai</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_ai" name="OCR / AI">
        <bpmn:flowNodeRef>ocr</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>classify</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>analyze</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_evidence</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>flag_evidence</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_lawyer" name="Luat su / Reviewer">
        <bpmn:flowNodeRef>lawyer_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>finding_review</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>gw_final</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>revise</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>draft_report</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>final_report</bpmn:flowNodeRef>
      </bpmn:lane>
      <bpmn:lane id="lane_cskh" name="CSKH / Follow-up">
        <bpmn:flowNodeRef>deliver</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>roadmap</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>retainer</bpmn:flowNodeRef>
        <bpmn:flowNodeRef>end</bpmn:flowNodeRef>
      </bpmn:lane>
    </bpmn:laneSet>
    <bpmn:startEvent id="start" name="Bat dau">
      <bpmn:outgoing>f1</bpmn:outgoing>
    </bpmn:startEvent>
    <bpmn:userTask id="landing" name="Truy cap landing page - va bam dang ky">
      <bpmn:incoming>f1</bpmn:incoming>
      <bpmn:outgoing>f2</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="intake_form" name="Dien form intake 3 buoc - Doanh nghiep - pham vi - lien he">
      <bpmn:incoming>f2</bpmn:incoming>
      <bpmn:outgoing>f3</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="create_lead" name="Tao lead + survey request - contact + organization + ho so nhap">
      <bpmn:incoming>f3</bpmn:incoming>
      <bpmn:outgoing>f4</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="otp" name="Xac thuc OTP email">
      <bpmn:incoming>f4</bpmn:incoming>
      <bpmn:outgoing>f5</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="receive_lead" name="Intake nhan lead - tren dashboard">
      <bpmn:incoming>f5</bpmn:incoming>
      <bpmn:outgoing>f6</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="check_info" name="Kiem tra thong tin - khach hang">
      <bpmn:incoming>f6</bpmn:incoming>
      <bpmn:outgoing>f7</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_conflict" name="Conflict - clear?">
      <bpmn:incoming>f7</bpmn:incoming>
      <bpmn:outgoing>f8</bpmn:outgoing>
      <bpmn:outgoing>f9</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:endEvent id="stop_conflict" name="Dung / cho - partner duyet">
      <bpmn:incoming>f8</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:userTask id="proposal" name="Gui bao phi - Tao hop dong">
      <bpmn:incoming>f9</bpmn:incoming>
      <bpmn:outgoing>f10</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="payment" name="Ky hop dong - va thanh toan">
      <bpmn:incoming>f10</bpmn:incoming>
      <bpmn:outgoing>f11</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="open_case" name="Mo ho so chinh thuc - Sinh ma + tao Drive">
      <bpmn:incoming>f11</bpmn:incoming>
      <bpmn:outgoing>f12</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="upload_docs" name="Upload tai lieu - theo checklist">
      <bpmn:incoming>f12</bpmn:incoming>
      <bpmn:outgoing>f13</bpmn:outgoing>
      <bpmn:incoming>f17</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:serviceTask id="store_docs" name="Luu metadata - file, trang thai, audit">
      <bpmn:incoming>f13</bpmn:incoming>
      <bpmn:outgoing>f14</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="check_docs" name="Kiem tra checklist - tai lieu">
      <bpmn:incoming>f14</bpmn:incoming>
      <bpmn:outgoing>f15</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_docs" name="Tai lieu - du?">
      <bpmn:incoming>f15</bpmn:incoming>
      <bpmn:outgoing>f16</bpmn:outgoing>
      <bpmn:outgoing>f18</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="request_more" name="Yeu cau bo sung - tai lieu">
      <bpmn:incoming>f16</bpmn:incoming>
      <bpmn:outgoing>f17</bpmn:outgoing>
      <bpmn:incoming>f29</bpmn:incoming>
    </bpmn:userTask>
    <bpmn:userTask id="handoff_ai" name="Chuyen xu ly - OCR / AI">
      <bpmn:incoming>f18</bpmn:incoming>
      <bpmn:outgoing>f19</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="ocr" name="OCR tai lieu">
      <bpmn:incoming>f19</bpmn:incoming>
      <bpmn:outgoing>f20</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="classify" name="AI phan loai - tai lieu">
      <bpmn:incoming>f20</bpmn:incoming>
      <bpmn:outgoing>f21</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="analyze" name="AI phan tich rui ro - tao finding draft">
      <bpmn:incoming>f21</bpmn:incoming>
      <bpmn:outgoing>f22</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:exclusiveGateway id="gw_evidence" name="Co - evidence?">
      <bpmn:incoming>f22</bpmn:incoming>
      <bpmn:outgoing>f23</bpmn:outgoing>
      <bpmn:outgoing>f25</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:serviceTask id="flag_evidence" name="Gan co kiem tra - thieu evidence">
      <bpmn:incoming>f23</bpmn:incoming>
      <bpmn:outgoing>f24</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="lawyer_review" name="Luat su review - tai lieu goc + AI draft">
      <bpmn:incoming>f24</bpmn:incoming>
      <bpmn:incoming>f25</bpmn:incoming>
      <bpmn:outgoing>f26</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="finding_review" name="Accept / Edit / Reject - tung finding">
      <bpmn:incoming>f26</bpmn:incoming>
      <bpmn:outgoing>f27</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:exclusiveGateway id="gw_final" name="Du dieu kien - final?">
      <bpmn:incoming>f27</bpmn:incoming>
      <bpmn:outgoing>f28</bpmn:outgoing>
      <bpmn:outgoing>f30</bpmn:outgoing>
    </bpmn:exclusiveGateway>
    <bpmn:userTask id="revise" name="Chinh sua - hoac bo sung">
      <bpmn:incoming>f28</bpmn:incoming>
      <bpmn:outgoing>f29</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:serviceTask id="draft_report" name="Tao bao cao nhap">
      <bpmn:incoming>f30</bpmn:incoming>
      <bpmn:outgoing>f31</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:serviceTask id="final_report" name="Duyet final - khoa version + xuat file">
      <bpmn:incoming>f31</bpmn:incoming>
      <bpmn:outgoing>f32</bpmn:outgoing>
    </bpmn:serviceTask>
    <bpmn:userTask id="deliver" name="Ban giao - bao cao">
      <bpmn:incoming>f32</bpmn:incoming>
      <bpmn:outgoing>f33</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="roadmap" name="Roadmap - 30-90 ngay">
      <bpmn:incoming>f33</bpmn:incoming>
      <bpmn:outgoing>f34</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:userTask id="retainer" name="De xuat - retainer">
      <bpmn:incoming>f34</bpmn:incoming>
      <bpmn:outgoing>f35</bpmn:outgoing>
    </bpmn:userTask>
    <bpmn:endEvent id="end" name="Ket thuc">
      <bpmn:incoming>f35</bpmn:incoming>
    </bpmn:endEvent>
    <bpmn:sequenceFlow id="f1" sourceRef="start" targetRef="landing" />
    <bpmn:sequenceFlow id="f2" sourceRef="landing" targetRef="intake_form" />
    <bpmn:sequenceFlow id="f3" sourceRef="intake_form" targetRef="create_lead" />
    <bpmn:sequenceFlow id="f4" sourceRef="create_lead" targetRef="otp" />
    <bpmn:sequenceFlow id="f5" sourceRef="otp" targetRef="receive_lead" />
    <bpmn:sequenceFlow id="f6" sourceRef="receive_lead" targetRef="check_info" />
    <bpmn:sequenceFlow id="f7" sourceRef="check_info" targetRef="gw_conflict" />
    <bpmn:sequenceFlow id="f8" name="No" sourceRef="gw_conflict" targetRef="stop_conflict" />
    <bpmn:sequenceFlow id="f9" name="Yes" sourceRef="gw_conflict" targetRef="proposal" />
    <bpmn:sequenceFlow id="f10" sourceRef="proposal" targetRef="payment" />
    <bpmn:sequenceFlow id="f11" sourceRef="payment" targetRef="open_case" />
    <bpmn:sequenceFlow id="f12" sourceRef="open_case" targetRef="upload_docs" />
    <bpmn:sequenceFlow id="f13" sourceRef="upload_docs" targetRef="store_docs" />
    <bpmn:sequenceFlow id="f14" sourceRef="store_docs" targetRef="check_docs" />
    <bpmn:sequenceFlow id="f15" sourceRef="check_docs" targetRef="gw_docs" />
    <bpmn:sequenceFlow id="f16" name="No" sourceRef="gw_docs" targetRef="request_more" />
    <bpmn:sequenceFlow id="f17" name="Bo sung" sourceRef="request_more" targetRef="upload_docs" />
    <bpmn:sequenceFlow id="f18" name="Yes" sourceRef="gw_docs" targetRef="handoff_ai" />
    <bpmn:sequenceFlow id="f19" sourceRef="handoff_ai" targetRef="ocr" />
    <bpmn:sequenceFlow id="f20" sourceRef="ocr" targetRef="classify" />
    <bpmn:sequenceFlow id="f21" sourceRef="classify" targetRef="analyze" />
    <bpmn:sequenceFlow id="f22" sourceRef="analyze" targetRef="gw_evidence" />
    <bpmn:sequenceFlow id="f23" name="No" sourceRef="gw_evidence" targetRef="flag_evidence" />
    <bpmn:sequenceFlow id="f24" sourceRef="flag_evidence" targetRef="lawyer_review" />
    <bpmn:sequenceFlow id="f25" name="Yes" sourceRef="gw_evidence" targetRef="lawyer_review" />
    <bpmn:sequenceFlow id="f26" sourceRef="lawyer_review" targetRef="finding_review" />
    <bpmn:sequenceFlow id="f27" sourceRef="finding_review" targetRef="gw_final" />
    <bpmn:sequenceFlow id="f28" name="No" sourceRef="gw_final" targetRef="revise" />
    <bpmn:sequenceFlow id="f29" name="Bo sung" sourceRef="revise" targetRef="request_more" />
    <bpmn:sequenceFlow id="f30" name="Yes" sourceRef="gw_final" targetRef="draft_report" />
    <bpmn:sequenceFlow id="f31" sourceRef="draft_report" targetRef="final_report" />
    <bpmn:sequenceFlow id="f32" sourceRef="final_report" targetRef="deliver" />
    <bpmn:sequenceFlow id="f33" sourceRef="deliver" targetRef="roadmap" />
    <bpmn:sequenceFlow id="f34" sourceRef="roadmap" targetRef="retainer" />
    <bpmn:sequenceFlow id="f35" sourceRef="retainer" targetRef="end" />
  </bpmn:process>
