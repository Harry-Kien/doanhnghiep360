# Legal360 production env sample.
# Copy to .env.production, fill real values, then run:
# npm run check:env -- .env.production

NEXT_PUBLIC_APP_NAME="Legal360 - Ngoc Son & Partners"
APP_BASE_URL="https://your-domain.vn"
AUTH_SECRET="replace-with-64-random-hex-or-strong-secret"

ADMIN_EMAIL="admin@your-domain.vn"
ADMIN_PASSWORD="replace-with-strong-admin-password"

# Vercel/serverless: use Supabase/Postgres. VPS with durable disk may use "sqlite".
DATA_STORE="supabase"
DATABASE_URL="postgres://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres"

DRIVE_PROVIDER="google"
GOOGLE_PROJECT_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
GOOGLE_SHARED_DRIVE_ID=""
GOOGLE_WORKSPACE_DOMAIN=""
GOOGLE_SHEET_ID=""

EMAIL_PROVIDER="smtp"
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Legal360 <no-reply@your-domain.vn>"

OCR_PROVIDER="local"

AI_PROVIDER="gemini"
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"

GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI="https://your-domain.vn/api/auth/google/callback"
