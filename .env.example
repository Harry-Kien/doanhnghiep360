# Legal360 local/dev env sample.
# Copy to .env.local for local testing only.
# For production, use .env.production.example and run: npm run check:env -- .env.production

NEXT_PUBLIC_APP_NAME="Legal360 - Ngoc Son & Partners"
APP_BASE_URL="http://localhost:3000"
AUTH_SECRET="change-this-local-secret-before-production"

# Local defaults: mock providers keep the app runnable without external keys.
DRIVE_PROVIDER="mock"
OCR_PROVIDER="mock"
AI_PROVIDER="mock"
EMAIL_PROVIDER="mock"

# Runtime store. sqlite persists to .data/legal360.db; .data is gitignored.
DATA_STORE="sqlite"

# Supabase/Postgres target for Vercel or migration scripts. Never expose this as NEXT_PUBLIC_*.
DATABASE_URL=""

# Optional Google Drive, required only when DRIVE_PROVIDER=google.
GOOGLE_PROJECT_ID=""
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_PRIVATE_KEY=""
GOOGLE_DRIVE_ROOT_FOLDER_ID=""
GOOGLE_SHARED_DRIVE_ID=""
GOOGLE_WORKSPACE_DOMAIN=""
GOOGLE_SHEET_ID=""

# Optional Google OAuth for customer login.
GOOGLE_OAUTH_CLIENT_ID=""
GOOGLE_OAUTH_CLIENT_SECRET=""
GOOGLE_OAUTH_REDIRECT_URI=""

# Optional SMTP, required only when EMAIL_PROVIDER=smtp.
SMTP_HOST=""
SMTP_PORT="587"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="Legal360 <no-reply@luatngocson.com>"

# Optional OCR/AI providers.
AZURE_DOCINTEL_ENDPOINT=""
AZURE_DOCINTEL_KEY=""
GEMINI_API_KEY=""
GEMINI_MODEL="gemini-2.5-flash"
ANTHROPIC_API_KEY=""
ANTHROPIC_MODEL="claude-opus-4-8"

# Production seed admin. In NODE_ENV=production with empty DB, only this admin is created.
ADMIN_EMAIL="admin@legal360.vn"
ADMIN_PASSWORD="Legal360@Admin"
